{
  "Automation": {
    "Environment": "Development",
    "UiBaseUrl": "https://your-app.dev.example.com",
    "Browser": {
      "BrowserType": "chromium",
      "Headless": true,
      "DefaultTimeoutMs": 30000,
      "RetryCount": 2,
      "RetryDelayMs": 500,
      "ScreenshotOnFailure": true,
      "ScreenshotOnSuccess": false,
      "TraceOnFailure": false,
      "VideoOnFailure": false,
      "ViewportWidth": 1920,
      "ViewportHeight": 1080,
      "AcceptDownloads": true,
      "IgnoreHttpsErrors": false,
      "SlowMoMs": 0
    },
    "Api": {
      "BaseUrl": "https://api.dev.example.com",
      "TimeoutSeconds": 30,
      "RetryCount": 2,
      "RetryDelayMs": 300,
      "AttachRequestToReport": true,
      "AttachResponseToReport": true
    },
    "Report": {
      "AllureResultsDirectory": "allure-results",
      "WriteEnvironmentProperties": true,
      "AttachLogOnFailure": true
    }
  }
}
