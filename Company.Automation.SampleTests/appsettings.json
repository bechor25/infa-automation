{
  "Automation": {
    "Environment": "Development",
    "UiBaseUrl": "https://the-internet.herokuapp.com",
    "Browser": {
      "BrowserType": "chromium",
      "Headless": true,
      "DefaultTimeoutMs": 30000,
      "RetryCount": 2,
      "RetryDelayMs": 500,
      "ScreenshotOnFailure": true
    },
    "Api": {
      "BaseUrl": "https://jsonplaceholder.typicode.com",
      "TimeoutSeconds": 30,
      "RetryCount": 1,
      "AttachRequestToReport": true,
      "AttachResponseToReport": true
    },
    "Report": {
      "AllureResultsDirectory": "allure-results",
      "WriteEnvironmentProperties": true
    }
  }
}
